# Environment Variables Example
# Copy this to .env and fill in your actual values

# OpenRouter API Key
# This should match the Cloudflare secret name "openrouter"
# For Cloudflare deployment: Create a secret named "openrouter" with your API key
VITE_OPENROUTER_API_KEY=your_openrouter_api_key_here

# PDFShift API Key for PDF generation
VITE_PDFSHIFT_API_KEY=your_pdfshift_api_key_here
